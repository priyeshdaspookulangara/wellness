# Apache Server Configs
<IfModule mod_rewrite.c>
    RewriteEngine On
    # No RewriteRules are currently used for the directory-based URL structure.
    # Apache's DirectoryIndex directive (usually defaulting to index.php) handles this.
    # RewriteBase /wellness-platform/ # This would be relevant if using relative RewriteRules.
</IfModule>

# Custom Error Pages
# This path is relative to the DocumentRoot.
# If your site is http://localhost/wellness-platform/, this path is correct.
# If your site is http://localhost/, this path would be /404.php.
ErrorDocument 404 /wellness-platform/404.php

# Disable directory browsing
Options -Indexes

# Set default charset
AddDefaultCharset UTF-8

# Basic security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    # Header set Content-Security-Policy "default-src 'self';" # Requires careful configuration
</IfModule>
